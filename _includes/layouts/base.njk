<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "Matej Vrzala" }}</title>
  <meta name="description" content="{{ description or "Personal website and engineering blog of Matej Vrzala." }}">
  <link rel="stylesheet" href="/assets/css/style.css">
  <!-- Prism Syntax Highlighting Styles -->
  <link href="https://unpkg.com/prismjs@1.29.0/themes/prism.css" rel="stylesheet" />
  
  <!-- Blocking Script to initialize theme color flash-free -->
  <script>
    (function() {
      const savedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = savedTheme || (prefersDark ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>

  <!-- MathJax for rendering math formulas -->
  <script>
    window.MathJax = {
      tex: {
        inlineMath: [['$', '$'], ['\\(', '\\)']],
        displayMath: [['$$', '$$'], ['\\[', '\\]']]
      }
    };
  </script>
  <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js" id="MathJax-script" async></script>
</head>
<body>
  <header class="site-header">
    <div class="header-container">
      <a href="/" class="logo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
        </svg>
        <span>Matej Vrzala</span>
      </a>
      <div class="nav-links-wrapper">
        <nav>
          <ul class="nav-links">
            <li><a href="/" class="{% if page.url == '/' %}active{% endif %}">Home</a></li>
            <li><a href="/#about">About</a></li>
            <li><a href="/#writings">Writings</a></li>
          </ul>
        </nav>
        <button id="theme-toggle" aria-label="Toggle Theme" class="theme-toggle-btn">
          <!-- Sun Icon (visible in dark mode) -->
          <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
          <!-- Moon Icon (visible in light mode) -->
          <svg class="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <main class="main-content">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <p>&copy; 2026 Matej Vrzala. Built with <a href="https://www.11ty.dev/" target="_blank" rel="noopener">Eleventy</a>.</p>
  </footer>

  <!-- Script to process theme toggle, Mermaid blocks, and run Mermaid client-side -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // Theme Toggle Logic
      const toggleBtn = document.getElementById('theme-toggle');
      if (toggleBtn) {
        toggleBtn.addEventListener('click', () => {
          const currentTheme = document.documentElement.getAttribute('data-theme');
          const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', newTheme);
          localStorage.setItem('theme', newTheme);
          
          // Re-render Mermaid by reloading page if Mermaid diagram is present
          if (document.querySelector('.mermaid')) {
            window.location.reload();
          }
        });
      }

      // Find code blocks containing mermaid code and convert them
      document.querySelectorAll('pre code.language-mermaid').forEach((codeBlock) => {
        const pre = codeBlock.parentElement;
        const mermaidDiv = document.createElement('div');
        mermaidDiv.className = 'mermaid';
        mermaidDiv.textContent = codeBlock.textContent;
        pre.replaceWith(mermaidDiv);
      });

      // Initialize Mermaid only if there is a block to render
      if (document.querySelector('.mermaid')) {
        const currentTheme = document.documentElement.getAttribute('data-theme');
        import('https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs')
          .then(m => m.default.initialize({ 
            startOnLoad: true, 
            theme: currentTheme === 'dark' ? 'dark' : 'default',
            securityLevel: 'loose'
          }));
      }
    });
  </script>
</body>
</html>
